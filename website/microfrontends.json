{
    "$schema": "https://openapi.vercel.sh/microfrontends.json",
    "applications": {
      "runmat": {
        "routing": [
          { "paths": ["/_next/static/:path*"] },
          { "paths": ["/_next/image"] },
          { "paths": ["/_next/data/:path*"] },
          { "paths": ["/sitemap.xml"] },
          { "paths": ["/robots.txt"] },
          { "paths": ["/favicon.ico"] },
          { "paths": ["/docs/:path*"] },
          { "paths": ["/blog/:path*"] },
          { "paths": ["/benchmarks/:path*"] },
          { "paths": ["/resources/:path*"] },
          { "paths": ["/download"] },
          { "paths": ["/license"] },
          { "paths": ["/api/:path*"] },
          { "paths": ["/"] }
        ]
      },
      "runmat-desktop": {
        "routing": [
          {
            "paths": ["/sandbox"]
          },
          {
            "paths": ["/_p/:path*"]
          },
          {
            "paths": ["/js/:path*"]
          },
          {
            "paths": ["/sQuv/:path*"]
          },
          {
            "paths": ["/sQuv/static/:path*"]
          }
        ]
      }
    }
}